# Description:
# Ignore rules for MeedyaManager project across macOS, Windows,
# VS Code, Xcode, and Visual Studio environments.
# Also handles secrets, env files, and dev/testing tools.
# ============================================================================

# OS-specific
.DS_Store
Thumbs.db
Icon?
__MACOSX/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
venv/
.venv/
ENV/
env/

# Logs, cache
*.log
*.tmp
*.bak
*.swp
*.swo
*.orig

# Pytest
.cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Tox
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# VS Code
.vscode/

# Visual Studio (Community/Pro)
.vs/
*.vcxproj.user
*.suo
*.ncb
*.aps
*.sdf
*.opendb
*.VC.db
ipch/

# Xcode / macOS
*.xcworkspace
*.xcodeproj
*.xcuserdata/
*.xcuserstate
*.xcsettings
DerivedData/
build/

# Packaging & Artifacts
*.tar.gz
*.zip
*.dmg
dist/
logs/
*.egg
*.egg-info/
build/

# Node/npm (in case frontend included later)
node_modules/
package-lock.json
yarn.lock

# Editor backups
*~
*.bak
*.tmp
*.orig

# Secrets & environment overrides
.env
.env.*
.secrets
.secrets.*
settings.local.json5

# Project-specific
*.sqlite3
*.db
*.metadata.json

# JetBrains IDEs (PyCharm, WebStorm, etc)
.idea/

# PyInstaller / Nuitka
*.spec
*.onefile-build/
*.onedir-build/

# PySide6 / Qt
*.qmlc
*.jsc
ui_*.py
*_rc.py

# Ruff / linting
.ruff_cache/

# Claude Code session logs
.claude/*.jsonl