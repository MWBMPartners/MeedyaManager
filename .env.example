# ============================================================================
# File: /.env.example
# (C) 2025-2026 MWBM Partners Ltd
#
# Description:
# Example .env file to be copied and renamed to `.env` for development.
# Stores fallback API keys and environment-specific overrides.
# This file is excluded via .gitignore and is not tracked.
#
# Priority chain: .env → settings.json5 → OS keyring → encrypted bundle
# ============================================================================

# ── Apple Music (JWT auth — requires Apple Developer Program) ──
APPLE_MUSIC_TEAM_ID=                  # 10-char Apple Developer Team ID
APPLE_MUSIC_KEY_ID=                   # MusicKit private key ID
APPLE_MUSIC_PRIVATE_KEY=              # Path to .p8 private key file (or PEM string)

# ── Spotify (OAuth2 Client Credentials) ──
SPOTIFY_CLIENT_ID=                    # From Spotify Developer Dashboard
SPOTIFY_CLIENT_SECRET=                # From Spotify Developer Dashboard

# ── MusicBrainz (User-Agent only — no API key required) ──
MUSICBRAINZ_CONTACT_EMAIL=            # Contact email for User-Agent header

# ── Deezer (public API — no auth required for search) ──
# No credentials needed for Deezer search API

# ── Tidal (OAuth2.1) ──
TIDAL_CLIENT_ID=                      # From TIDAL Developer Portal
TIDAL_CLIENT_SECRET=                  # From TIDAL Developer Portal

# ── YouTube Music (browser-cookie auth) ──
YOUTUBE_MUSIC_HEADERS_AUTH=           # Path to headers_auth.json (from ytmusicapi setup)

# ── Amazon Music (closed beta — best effort) ──
AMAZON_MUSIC_AUTH=                    # Community library auth token (if available)

# ── Shazam (no auth required) ──
# No credentials needed for Shazam (shazamio)

# ── iHeart (no auth required — undocumented endpoints) ──
# No credentials needed for iHeart

# ── Pandora (no public API — stub provider) ──
# No credentials available for Pandora

# ── Apple Podcasts, iTunes Store, Apple TV (public iTunes Search API) ──
# No credentials needed for iTunes Search API

# ── TMDB (free API key) ──
TMDB_API_KEY=                         # From themoviedb.org account settings

# ── TheTVDB (free API key, JWT token flow) ──
TVDB_API_KEY=                         # From thetvdb.com dashboard

# ── IMDb (cinemagoer — no auth, scraping-based) ──
# No credentials needed (uses cinemagoer library)

# ── EIDR (HTTP Basic Auth — paid membership required) ──
EIDR_CLIENT_ID=                       # EIDR membership client ID
EIDR_CLIENT_SECRET=                   # EIDR membership client secret

# ── ISRC / ISWC (federated — uses MusicBrainz + other providers) ──
# No separate credentials needed (uses MusicBrainz + Spotify/Deezer)

# ── Optional Local Overrides ──
METAMANCER_PROFILE_NAME=dev
METAMANCER_FALLBACK_LANGUAGE=en
METAMANCER_REGION_DEFAULT=GB

# ── Logging and Debugging ──
METAMANCER_LOG_LEVEL=INFO
