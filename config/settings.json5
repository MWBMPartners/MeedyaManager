// ============================================================================
// File: config/settings.json5
// (C) 2025 MWBM Partners Ltd (d/b/a MW Services)
//
// Description:
// This file defines the user-editable configuration settings for MeedyaManager.
// It includes folder paths to monitor, allowed extensions, filename rules,
// and fallback metadata classification defaults if MediaInfo fails or tags
// are missing.
// ============================================================================

{
  // Directories to watch
  watch_paths: [
    "~/Downloads/Media",
    "~/Desktop/NewMedia"
  ],

  // Supported extensions for processing (auto-lowercased)
  valid_extensions: ["mp3", "flac", "m4a", "mp4", "mkv", "avi", "wav", "pdf", "jpg", "jpeg", "png", "ogg", "ac3", "alac"],

  // Rename template using MusicBee-style syntax (see help/rule-syntax.md)
  // Tags: <Tag Name>, Functions: $FuncName(), e.g. $Pad(<Track #>,2)
  rename_format: "<Media Class>/<Artist>/<Album>/<$Pad(<Track #>,2)> - <Title>.<Ext>",

  // Default fallback values for metadata classification if unavailable
  fallback_metadata: {
    media_group: "Audio",
    format_class: "unknown",
    media_class: "Music",
    quality_type: "Lossy"
  },

  // Rename settings
  filename_replacements: {
    "/": "-",
    "\\\\": "-",
    ":": "-",
    "*": "",
    "?": "",
    "\"": "'",
    "<": "",
    ">": "",
    "|": ""
  }
}
