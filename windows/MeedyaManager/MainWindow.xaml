<Window
    x:Class="MeedyaManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MeedyaManager"
    Title="MeedyaManager">

    <!-- Main navigation layout using WinUI 3 NavigationView -->
    <NavigationView
        x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        SelectionChanged="NavView_SelectionChanged">

        <!-- Navigation menu items -->
        <NavigationView.MenuItems>
            <!-- Library — browse and manage media files -->
            <NavigationViewItem Content="Library" Tag="Library">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Library" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Rules — configure auto-organization rules -->
            <NavigationViewItem Content="Rules" Tag="Rules">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Filter" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Metadata — view and edit file metadata -->
            <NavigationViewItem Content="Metadata" Tag="Metadata">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Tag" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Lookup — search metadata providers -->
            <NavigationViewItem Content="Lookup" Tag="Lookup">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Find" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- Settings item in the footer area -->
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Settings" Tag="Settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <!-- Content area — hosts the currently selected page -->
        <Frame x:Name="ContentFrame" />

    </NavigationView>

</Window>
