<Window
    x:Class="MeedyaManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MeedyaManager"
    Title="MeedyaManager">

    <!-- Main navigation layout using WinUI 3 NavigationView -->
    <NavigationView
        x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        SelectionChanged="NavView_SelectionChanged">

        <!-- Navigation menu items -->
        <NavigationView.MenuItems>
            <!-- Library — browse and manage media files -->
            <NavigationViewItem Content="Library" Tag="Library">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Library" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Rules — configure auto-organization rules -->
            <NavigationViewItem Content="Rules" Tag="Rules">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Filter" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Metadata — view and edit file metadata -->
            <NavigationViewItem Content="Metadata" Tag="Metadata">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Tag" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Lookup — search metadata providers -->
            <NavigationViewItem Content="Lookup" Tag="Lookup">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Find" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Cloud — cloud storage monitor (M7) -->
            <NavigationViewItem Content="Cloud" Tag="Cloud">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Cloud" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <!-- Export — database export (M9) -->
            <NavigationViewItem Content="Export" Tag="Export">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Save" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- Settings item in the footer area -->
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Settings" Tag="Settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <!-- Content area — update InfoBar + page frame stacked vertically -->
        <Grid>
            <Grid.RowDefinitions>
                <!-- Update notification bar (auto-height; collapses when not visible) -->
                <RowDefinition Height="Auto" />
                <!-- Main page content -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Update notification InfoBar (M8) — shown when a newer version
                 is detected by the UpdateChecker background task.
                 IsOpen is toggled from MainWindow.xaml.cs after the check. -->
            <InfoBar
                x:Name="UpdateInfoBar"
                Grid.Row="0"
                IsOpen="False"
                Severity="Informational"
                Title="Update available"
                Message="A new version of MeedyaManager is available. Download it from GitHub."
                IsClosable="True">
                <InfoBar.ActionButton>
                    <HyperlinkButton
                        Content="Download"
                        NavigateUri="https://github.com/MWBMPartners/MeedyaManager/releases/latest" />
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Page content frame — navigates between Library, Rules, etc. -->
            <Frame x:Name="ContentFrame" Grid.Row="1" />
        </Grid>

    </NavigationView>

</Window>
