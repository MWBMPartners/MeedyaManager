<!--
  (C) 2025-2026 MWBM Partners Ltd
  MeedyaManager — Windows (WinUI 3) string resources — English (United States)

  This file contains all user-visible strings for the MeedyaManager Windows app.
  Strings are keyed by a dot-separated identifier (Page.Context.Name).

  To add a new language:
    1. Create windows/MeedyaManager/Strings/<lang-tag>/Resources.resw
       (e.g. Strings/fr-FR/Resources.resw for French)
    2. Copy all <data> elements from this file into the new file.
    3. Translate the <value> text for each key.
    4. WinUI 3 / ResourceLoader will pick up the correct locale automatically.

  Usage in code-behind (C#):
    using Windows.ApplicationModel.Resources;
    private static readonly ResourceLoader _res = new();
    string label = _res.GetString("Scan/Folder/Label");

  Usage in XAML:
    x:Uid="Scan_Button_Scan"   (maps to Scan.Button.Scan.Content / .Text etc.)
-->
<root>

  <!--
    Schema information — do not remove; required by Visual Studio and ResGen.
  -->
  <resheader name="resmimetype">
    <value>text/microsoft-resx</value>
  </resheader>
  <resheader name="version">
    <value>2.0</value>
  </resheader>
  <resheader name="reader">
    <value>System.Resources.ResXResourceReader, System.Windows.Forms</value>
  </resheader>
  <resheader name="writer">
    <value>System.Resources.ResXResourceWriter, System.Windows.Forms</value>
  </resheader>

