  </data>

  <data name="Settings.Button.OpenFolder" xml:space="preserve">
    <value>Open Folder</value>
    <comment>Button to open the config directory in Explorer</comment>
  </data>

  <data name="Settings.Button.CopyPath" xml:space="preserve">
    <value>Copy Path</value>
    <comment>Button to copy the config file path to the clipboard</comment>
  </data>

  <data name="Settings.Status.Saved" xml:space="preserve">
    <value>Settings saved.</value>
    <comment>Status shown after settings are saved successfully</comment>
  </data>

  <!-- ===================================================================
       Server page
       =================================================================== -->

  <data name="Server.Button.Start" xml:space="preserve">
    <value>Start Server</value>
    <comment>Button to start the HTTPS media server</comment>
  </data>

  <data name="Server.Button.Stop" xml:space="preserve">
    <value>Stop Server</value>
    <comment>Button to stop the running HTTPS media server</comment>
  </data>

  <data name="Server.Button.Routes" xml:space="preserve">
    <value>Show Routes</value>
    <comment>Button to display the HTTP route table in the log</comment>
  </data>

  <data name="Server.Button.ClearLog" xml:space="preserve">
    <value>Clear Log</value>
    <comment>Button to clear the server access log</comment>
  </data>

  <data name="Server.Status.Stopped" xml:space="preserve">
    <value>Status: stopped</value>
    <comment>Status label when the server is not running</comment>
  </data>

  <data name="Server.Status.Running" xml:space="preserve">
    <value>Status: running — {0}</value>
    <comment>Status label when the server is running; {0} = bind address</comment>
  </data>

  <!-- ===================================================================
       Common / shared
       =================================================================== -->

  <data name="Common.Button.Cancel" xml:space="preserve">
    <value>Cancel</value>
    <comment>Generic Cancel button label</comment>
  </data>

  <data name="Common.Button.Close" xml:space="preserve">
    <value>Close</value>
    <comment>Generic Close button label</comment>
  </data>

  <data name="Common.Error.Generic" xml:space="preserve">
    <value>An error occurred: {0}</value>
    <comment>Generic error message shown in status labels; {0} = error detail</comment>
  </data>

</root>
