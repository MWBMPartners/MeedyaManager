<!--
    MeedyaManager — Metadata Lookup Page (WinUI 3, M6)

    Lets users search metadata providers and apply results to open files.

    Layout:
      Left pane:  Query / Artist fields, Search button, results list, detail card, Apply / Clear
      Right pane: Provider checklist (enabled/disabled per provider)
-->
<Page
    x:Class="MeedyaManager.Views.LookupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="Transparent">

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <!-- Left pane: search + results -->
            <ColumnDefinition Width="*" />
            <!-- Splitter -->
            <ColumnDefinition Width="Auto" />
            <!-- Right pane: provider selector -->
            <ColumnDefinition Width="220" MinWidth="180" MaxWidth="280" />
        </Grid.ColumnDefinitions>

        <!-- ── Left pane ──────────────────────────────────────────────────── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <!-- Search form -->
                <RowDefinition Height="Auto" />
                <!-- Results list -->
                <RowDefinition Height="*" />
                <!-- Detail card -->
                <RowDefinition Height="Auto" />
                <!-- Action bar -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search form -->
            <StackPanel Grid.Row="0" Spacing="8" Padding="16,16,16,8">
                <TextBlock
                    Text="Metadata Lookup"
                    Style="{StaticResource SubtitleTextBlockStyle}" />

                <TextBox
                    x:Name="QueryBox"
                    Header="Track / show / podcast title"
                    PlaceholderText="Enter a title to search…" />

                <TextBox
                    x:Name="ArtistBox"
                    Header="Artist (optional)"
                    PlaceholderText="Artist name…" />

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <!-- Progress ring shown during search -->
                    <ProgressRing
                        x:Name="SearchProgress"
                        IsActive="False"
                        Width="20"
                        Height="20" />

                    <Button
                        x:Name="SearchButton"
                        Content="Search"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SearchButton_Click" />
                </StackPanel>
            </StackPanel>

            <!-- Results list -->
            <ListView
                x:Name="ResultsList"
                Grid.Row="1"
                SelectionMode="Single"
                SelectionChanged="ResultsList_SelectionChanged"
                ItemsSource="{x:Bind Results}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="8" Padding="4,4">
                            <Grid.ColumnDefinitions>
                                <!-- Score dot -->
                                <ColumnDefinition Width="10" />
                                <!-- Provider badge -->
                                <ColumnDefinition Width="100" />
                                <!-- Title / Artist -->
                                <ColumnDefinition Width="*" />
                                <!-- Score number -->
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>

                            <!-- Coloured score dot -->
                            <Ellipse
                                Grid.Column="0"
                                Width="8"
                                Height="8"
                                Fill="{Binding ScoreColor}"
                                VerticalAlignment="Center" />

                            <!-- Provider badge -->
                            <Border
                                Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="4"
                                Padding="4,2"
                                VerticalAlignment="Center">
                                <TextBlock
                                    Text="{Binding Provider}"
                                    FontSize="11"
                                    TextTrimming="CharacterEllipsis" />
                            </Border>

                            <!-- Display title and subtitle -->
                            <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{Binding DisplayTitle}"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{Binding DisplaySubtitle}"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Score value -->
                            <TextBlock
                                Grid.Column="3"
                                Text="{Binding ScoreText}"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Detail card for selected result -->
            <Border
                x:Name="DetailCard"
                Grid.Row="2"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                Margin="16,0,16,8"
                Padding="12">
                <Grid ColumnSpacing="8" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Title"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailTitle" TextTrimming="CharacterEllipsis" FontSize="12" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Artist"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailArtist" TextTrimming="CharacterEllipsis" FontSize="12" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Album"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailAlbum" TextTrimming="CharacterEllipsis" FontSize="12" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Year"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailYear" FontSize="12" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Genre"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetailGenre" FontSize="12" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Score"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DetailScore" FontSize="12" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Provider"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DetailProvider" FontSize="12" />
                </Grid>
            </Border>

            <!-- Action bar -->
            <Border
                Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status message -->
                    <TextBlock
                        Grid.Column="0"
                        x:Name="StatusText"
                        Text="Enter a title and click Search."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="12"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis" />

                    <!-- Clear button -->
                    <Button
                        Grid.Column="1"
                        x:Name="ClearButton"
                        Content="Clear"
                        Margin="0,0,8,0"
                        Click="ClearButton_Click" />

                    <!-- Apply to File button -->
                    <Button
                        Grid.Column="2"
                        x:Name="ApplyButton"
                        Content="Apply to File"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="ApplyButton_Click" />
                </Grid>
            </Border>
        </Grid>

        <!-- Splitter -->
        <Border Grid.Column="1" Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- ── Right pane: provider selector ──────────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="Providers"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Padding="12,12,12,8" />

            <!-- Provider toggles generated in code-behind -->
            <ListView
                Grid.Row="1"
                x:Name="ProviderList"
                SelectionMode="None"
                ItemsSource="{x:Bind Providers}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <CheckBox
                            Content="{Binding Label}"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            FontSize="{Binding FontSize}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                Grid.Row="2"
                Text="* = stub (no public API)"
                FontSize="10"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Padding="8,4" />
        </Grid>
    </Grid>
</Page>
