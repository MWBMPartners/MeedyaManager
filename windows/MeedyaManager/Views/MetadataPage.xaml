<!--
    MeedyaManager — Metadata Page (WinUI 3)

    Left column: file selector + audio properties summary.
    Right column: editable tag list + Save / Revert buttons.
-->
<Page
    x:Class="MeedyaManager.Views.MetadataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <!-- File info pane -->
            <ColumnDefinition Width="280" MinWidth="220" MaxWidth="360" />
            <!-- Splitter -->
            <ColumnDefinition Width="Auto" />
            <!-- Tag editor pane -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── File Info Pane ──────────────────────────────────────────── -->
        <StackPanel Grid.Column="0" Spacing="12" Padding="16">
            <TextBlock Text="Media File" Style="{StaticResource BodyStrongTextBlockStyle}" />

            <!-- File path display -->
            <TextBox
                x:Name="FilePathBox"
                PlaceholderText="No file selected"
                IsReadOnly="True"
                TextWrapping="Wrap"
                AutomationProperties.Name="Selected file path"
                AutomationProperties.HelpText="Shows the path of the currently loaded media file" />

            <Button
                x:Name="OpenFileButton"
                Content="Open File…"
                HorizontalAlignment="Stretch"
                Click="OpenFileButton_Click"
                AutomationProperties.Name="Open media file"
                AutomationProperties.HelpText="Opens a file picker to choose a media file for tag editing" />

            <!-- Cover art (shown when a URL is loaded by the metadata provider) -->
            <TextBlock
                Text="Cover Art"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Margin="0,8,0,0" />
            <Border
                CornerRadius="8"
                Width="160"
                Height="160"
                HorizontalAlignment="Left"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <!-- Placeholder icon shown when no art is available -->
                    <FontIcon
                        x:Name="CoverArtPlaceholder"
                        Glyph="&#xE8D6;"
                        FontSize="48"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <!-- Actual cover art image (hidden until URL is set) -->
                    <Image
                        x:Name="CoverArtImage"
                        Stretch="Uniform"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Audio properties -->
            <TextBlock
                Text="Audio Properties"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Margin="0,8,0,0" />
            <TextBlock
                x:Name="AudioPropsText"
                Text="—"
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontFamily="Cascadia Mono, Consolas, monospace"
                FontSize="12" />

            <!-- Progress + status -->
            <ProgressRing
                x:Name="LoadProgress"
                IsActive="False"
                HorizontalAlignment="Center" />
            <TextBlock
                x:Name="StatusText"
                Text=""
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                AutomationProperties.LiveSetting="Polite" />
        </StackPanel>

        <!-- Splitter -->
        <Border Grid.Column="1" Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- ── Tag Editor Pane ──────────────────────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Empty state -->
            <StackPanel
                x:Name="EmptyState"
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <FontIcon Glyph="&#xE8EC;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock
                    Text="Open a media file to view and edit its tags"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Tag list -->
            <ListView
                x:Name="TagList"
                Grid.Row="0"
                Visibility="Collapsed"
                SelectionMode="None"
                ItemsSource="{x:Bind TagRows}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12" Padding="4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Key label -->
                            <TextBlock
                                Grid.Column="0"
                                Text="{Binding Key}"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <!-- Editable value -->
                            <TextBox
                                Grid.Column="1"
                                Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="(empty)" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Save / Revert bar -->
            <Border
                Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Padding="16,10">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button
                        x:Name="RevertButton"
                        Content="Revert"
                        IsEnabled="False"
                        Click="RevertButton_Click"
                        AutomationProperties.Name="Revert changes"
                        AutomationProperties.HelpText="Discards all unsaved tag edits and reloads the file" />
                    <Button
                        x:Name="SaveButton"
                        Content="Save All"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="SaveButton_Click"
                        AutomationProperties.Name="Save metadata tags"
                        AutomationProperties.HelpText="Writes all edited tags back to the media file on disk" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
