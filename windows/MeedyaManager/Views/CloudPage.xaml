<!--
    MeedyaManager — Cloud Storage Monitor Page (WinUI 3, M7)

    Displays connected cloud providers, their sync status, and buttons to
    connect or disconnect each provider.

    Layout:
      Top:    Title + subtitle
      Middle: ListView of provider rows (Name | Status | Connect button)
      Bottom: Event log (read-only TextBox) + Clear button
-->
<Page
    x:Class="MeedyaManager.Views.CloudPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="Transparent">

    <Grid RowSpacing="0" Padding="24,16,24,16">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto" />
            <!-- Provider list -->
            <RowDefinition Height="Auto" />
            <!-- Separator -->
            <RowDefinition Height="Auto" />
            <!-- Event log label -->
            <RowDefinition Height="Auto" />
            <!-- Event log -->
            <RowDefinition Height="*" />
            <!-- Clear button row -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Title ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Cloud Storage Monitor"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Connect your cloud storage to automatically monitor media files."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- ── Provider list ─────────────────────────────────────────────── -->
        <ListView x:Name="ProviderList"
                  Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  Margin="0,0,0,8">
            <!-- Items populated in code-behind -->
        </ListView>

        <!-- ── Separator ─────────────────────────────────────────────────── -->
        <Rectangle Grid.Row="2"
                   Height="1"
                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                   Margin="0,4,0,8" />

        <!-- ── Event log label ───────────────────────────────────────────── -->
        <TextBlock Grid.Row="3"
                   Text="Event Log"
                   Style="{StaticResource BodyStrongTextBlockStyle}"
                   Margin="0,0,0,6" />

        <!-- ── Event log text box ────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,8">
            <TextBox x:Name="EventLogBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="11"
                     Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                     BorderThickness="1"
                     BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                     Padding="8"
                     MinHeight="120" />
        </ScrollViewer>

        <!-- ── Clear log button ──────────────────────────────────────────── -->
        <Button Grid.Row="5"
                x:Name="ClearLogButton"
                Content="Clear Log"
                HorizontalAlignment="Right"
                Click="ClearLogButton_Click" />

    </Grid>
</Page>
