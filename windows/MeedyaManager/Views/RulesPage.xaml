<!--
    MeedyaManager — Rules Page (WinUI 3, M6)

    Full template builder:
      - Rule name entry
      - Live template validator with per-keystroke feedback
      - Live preview computed with sample tags
      - Tag reference grid whose pill buttons insert tags at cursor position
-->
<Page
    x:Class="MeedyaManager.Views.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="24" MaxWidth="800">

            <!-- ── Template Validator ────────────────────────────────────── -->
            <TextBlock
                Text="Template Validator"
                Style="{StaticResource SubtitleTextBlockStyle}" />

            <TextBox
                x:Name="TemplateEntry"
                Header="Rename Template"
                PlaceholderText="e.g. &lt;Artist&gt; - &lt;Title&gt;"
                FontFamily="Cascadia Mono, Consolas, monospace"
                TextChanged="TemplateEntry_TextChanged" />

            <!-- Validation feedback InfoBar -->
            <InfoBar
                x:Name="ValidationBar"
                IsOpen="False"
                IsClosable="False" />

            <!-- ── Live Preview ───────────────────────────────────────────── -->
            <TextBlock
                Text="Live Preview"
                Style="{StaticResource SubtitleTextBlockStyle}" />

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                Padding="12">
                <TextBlock
                    x:Name="PreviewText"
                    Text="Enter a template above"
                    FontFamily="Cascadia Mono, Consolas, monospace"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>

            <!-- ── Available Tags ─────────────────────────────────────────── -->
            <TextBlock
                Text="Available Tags"
                Style="{StaticResource SubtitleTextBlockStyle}" />

            <TextBlock
                Text="Click a tag to insert it at the current cursor position."
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Tag pills generated in code-behind -->
            <ItemsControl x:Name="TagPills">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <muxc:WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Content="{Binding}"
                            Margin="4"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            FontSize="12"
                            Click="TagPill_Click" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Rule Name ──────────────────────────────────────────────── -->
            <TextBox
                x:Name="RuleNameBox"
                Header="Rule Name"
                PlaceholderText="e.g. Music Rule"
                Text="Default Rule" />

        </StackPanel>
    </ScrollViewer>
</Page>
