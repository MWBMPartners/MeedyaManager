     MeedyaManager — Server Page (WinUI 3 / M10)
     
     Provides server configuration controls and a start/stop interface for the
     MeedyaManager HTTPS media server.
-->
<Page
    x:Class="MeedyaManager.Views.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,20,24,20">
        <StackPanel Spacing="20" MaxWidth="680">

            <!-- Page header -->
            <TextBlock Text="Media Server"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Start the MeedyaManager HTTPS media server to stream your library remotely."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.7"
                       Margin="0,0,0,8"/>

            <!-- Network settings group -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Network" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bind address"
                                   VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="0" Grid.Column="1"
                                  x:Name="BindAddressBox"
                                  PlaceholderText="0.0.0.0"
                                  Text="0.0.0.0"
                                  ToolTipService.ToolTip="IP address to bind. Use 0.0.0.0 for all interfaces."/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="HTTPS port"
                                   VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="1" Grid.Column="1"
                                  x:Name="PortBox"
                                  PlaceholderText="8443"
                                  Text="8443"
                                  MaxWidth="100"
                                  HorizontalAlignment="Left"
                                  ToolTipService.ToolTip="TCP port. Ports below 1024 require elevated privileges."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- TLS settings group -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="TLS / HTTPS" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Certificate (PEM)"
                                   VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="0" Grid.Column="1"
                                  x:Name="CertPathBox"
                                  PlaceholderText="C:\ssl\cert.pem"
                                  ToolTipService.ToolTip="Path to PEM-encoded TLS certificate file."/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Private key (PEM)"
                                   VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="1" Grid.Column="1"
                                  x:Name="KeyPathBox"
                                  PlaceholderText="C:\ssl\key.pem"
                                  ToolTipService.ToolTip="Path to PEM-encoded TLS private key file."/>
                    </Grid>
                    <ToggleSwitch x:Name="NoTlsToggle"
                                  Header="Disable TLS (HTTP only — development use)"
                                  IsOn="False"
                                  ToolTipService.ToolTip="Serve plain HTTP instead of HTTPS. Not recommended for production."/>
                </StackPanel>
            </Border>

            <!-- Authentication group -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Authentication" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="JWT secret"
                                   VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="0" Grid.Column="1"
                                     x:Name="JwtSecretBox"
                                     PlaceholderText="or set MM_JWT_SECRET env var"
                                     ToolTipService.ToolTip="Secret used to sign JWT tokens. Minimum 16 characters."/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Token expiry (s)"
                                   VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="1" Grid.Column="1"
                                  x:Name="JwtExpiryBox"
                                  Text="86400"
                                  MaxWidth="100"
                                  HorizontalAlignment="Left"
                                  ToolTipService.ToolTip="JWT token lifetime in seconds. Default: 86400 (24 hours)."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CORS group -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="CORS" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Allowed origins" VerticalAlignment="Center"/>
                        <TextBox  Grid.Column="1"
                                  x:Name="CorsOriginsBox"
                                  PlaceholderText="https://app.example.com, https://local.dev:3000"
                                  ToolTipService.ToolTip="Comma-separated allowed CORS origins. Leave empty to deny all cross-origin requests."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Server control group -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Server Control" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <!-- Status -->
                    <TextBlock x:Name="StatusText"
                               Text="Status: Stopped"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.75"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="StartBtn"
                                Content="Start Server"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="StartBtn_Click"
                                ToolTipService.ToolTip="Start the HTTPS media server"/>
                        <Button x:Name="StopBtn"
                                Content="Stop Server"
                                IsEnabled="False"
                                Click="StopBtn_Click"
                                ToolTipService.ToolTip="Stop the running media server"/>
                        <Button x:Name="RoutesBtn"
                                Content="Show Routes"
                                Click="RoutesBtn_Click"
                                ToolTipService.ToolTip="Print the HTTP route table to the log"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Access log -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Access Log" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ScrollViewer x:Name="LogScroll" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogBox"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                    </ScrollViewer>
                    <Button x:Name="ClearLogBtn"
                            Content="Clear Log"
                            HorizontalAlignment="Right"
                            Click="ClearLogBtn_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
