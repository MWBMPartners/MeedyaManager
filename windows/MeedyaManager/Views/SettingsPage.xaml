<!--
    MeedyaManager — Settings Page (WinUI 3, M6)

    Displays and edits preferences. Changes can be saved back to the
    config file on disk via the Save Settings button (M6).
-->
<Page
    x:Class="MeedyaManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="24" MaxWidth="640">

            <!-- ── General ───────────────────────────────────────────────── -->
            <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ToggleSwitch
                x:Name="DryRunToggle"
                Header="Dry-run mode"
                OffContent="Renames are written to disk"
                OnContent="Renames are previewed only (no file changes)"
                AutomationProperties.HelpText="When on, renames are previewed only — no changes are written to disk" />

            <!-- ── Watching ───────────────────────────────────────────────── -->
            <TextBlock Text="Watching" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ToggleSwitch
                x:Name="RecursiveToggle"
                Header="Recursive scan"
                OffContent="Top-level files only"
                OnContent="Include sub-directories"
                IsOn="True"
                AutomationProperties.HelpText="When on, includes subdirectories when scanning a folder" />

            <NumberBox
                x:Name="DebounceBox"
                Header="Debounce interval (ms)"
                Value="500"
                Minimum="50"
                Maximum="5000"
                SpinButtonPlacementMode="Inline"
                SmallChange="50"
                AutomationProperties.Name="Debounce interval in milliseconds"
                AutomationProperties.HelpText="Milliseconds to wait before processing a file-system event. Range: 50 to 5000." />

            <!-- ── Logging ────────────────────────────────────────────────── -->
            <TextBlock Text="Logging" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ComboBox
                x:Name="LogLevelBox"
                Header="Log level"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Log level"
                AutomationProperties.HelpText="Controls the verbosity of structured log output">
                <x:String>error</x:String>
                <x:String>warn</x:String>
                <x:String>info</x:String>
                <x:String>debug</x:String>
                <x:String>trace</x:String>
            </ComboBox>

            <ToggleSwitch
                x:Name="RedactPiiToggle"
                Header="Redact PII in logs"
                OffContent="File paths and tags are logged as-is"
                OnContent="File paths and tags replaced with [REDACTED]"
                IsOn="True"
                AutomationProperties.HelpText="When on, replaces file paths and tag values with REDACTED in log output" />

            <!-- ── Test Mode ─────────────────────────────────────────────── -->
            <TextBlock Text="Test Mode" Style="{StaticResource SubtitleTextBlockStyle}" />

            <!-- Description of test mode behaviour -->
            <TextBlock
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="When enabled, all file operations (renames, tag writes) are journalled and reversible. Use this to safely preview changes before committing them to disk." />

            <!-- Test mode on/off toggle -->
            <ToggleSwitch
                x:Name="TestModeToggle"
                Header="Enable test mode"
                OffContent="File changes are applied immediately"
                OnContent="File changes are journalled (reversible)"
                Toggled="TestModeToggle_Toggled"
                AutomationProperties.HelpText="When on, all file changes are journalled and can be committed or reverted" />

            <!-- Tracked file count (visible only when test mode is active) -->
            <TextBlock
                x:Name="TestModeFileCountText"
                Visibility="Collapsed"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontSize="12"
                Text="Tracked files: 0" />

            <!-- Commit / Revert buttons (visible only when test mode has tracked files) -->
            <StackPanel
                x:Name="TestModeActionPanel"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="Collapsed">

                <Button
                    x:Name="TestModeCommitButton"
                    Content="Commit Changes"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="TestModeCommitButton_Click"
                    AutomationProperties.Name="Commit test mode changes"
                    AutomationProperties.HelpText="Makes all journalled file changes permanent" />

                <Button
                    x:Name="TestModeRevertButton"
                    Content="Revert Changes"
                    Click="TestModeRevertButton_Click"
                    AutomationProperties.Name="Revert test mode changes"
                    AutomationProperties.HelpText="Restores all files to their original state" />
            </StackPanel>

            <!-- ── Config File ────────────────────────────────────────────── -->
            <TextBlock Text="Config File" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="ConfigPathBox"
                    Grid.Column="0"
                    IsReadOnly="True"
                    FontFamily="Cascadia Mono, Consolas, monospace"
                    FontSize="12" />

                <Button
                    Grid.Column="1"
                    Content="Open Folder"
                    Click="OpenFolderButton_Click"
                    AutomationProperties.Name="Open config folder"
                    AutomationProperties.HelpText="Opens the folder containing the settings file in File Explorer" />

                <Button
                    Grid.Column="2"
                    Content="Copy Path"
                    Click="CopyPathButton_Click"
                    AutomationProperties.Name="Copy config file path"
                    AutomationProperties.HelpText="Copies the settings file path to the clipboard" />
            </Grid>

            <!-- Raw config preview -->
            <TextBlock Text="Raw Config (read-only)" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                MaxHeight="240">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox
                        x:Name="RawConfigBox"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Mono, Consolas, monospace"
                        FontSize="12"
                        BorderThickness="0"
                        Background="Transparent"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <!-- ── Save Settings ─────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock
                    x:Name="SaveStatusText"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="12" />
                <Button
                    x:Name="SaveButton"
                    Content="Save Settings"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SaveButton_Click"
                    AutomationProperties.Name="Save settings"
                    AutomationProperties.HelpText="Writes the current settings to the config file on disk" />
            </StackPanel>

            <!-- Core version -->
            <TextBlock
                x:Name="VersionText"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                FontSize="11" />

            <!-- Privacy Policy link -->
            <HyperlinkButton
                x:Name="PrivacyPolicyLink"
                Content="Privacy Policy"
                NavigateUri="https://github.com/MWBMPartners/MeedyaManager/blob/main/help/privacy-policy.md"
                HorizontalAlignment="Center"
                AutomationProperties.Name="Privacy Policy"
                AutomationProperties.HelpText="Opens the MeedyaManager privacy policy in your default browser" />

        </StackPanel>
    </ScrollViewer>
</Page>
