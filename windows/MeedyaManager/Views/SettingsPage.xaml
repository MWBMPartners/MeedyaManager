<!--
    MeedyaManager — Settings Page (WinUI 3, M6)

    Displays and edits preferences. Changes can be saved back to the
    config file on disk via the Save Settings button (M6).
-->
<Page
    x:Class="MeedyaManager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="24" MaxWidth="640">

            <!-- ── General ───────────────────────────────────────────────── -->
            <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ToggleSwitch
                x:Name="DryRunToggle"
                Header="Dry-run mode"
                OffContent="Renames are written to disk"
                OnContent="Renames are previewed only (no file changes)" />

            <!-- ── Watching ───────────────────────────────────────────────── -->
            <TextBlock Text="Watching" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ToggleSwitch
                x:Name="RecursiveToggle"
                Header="Recursive scan"
                OffContent="Top-level files only"
                OnContent="Include sub-directories"
                IsOn="True" />

            <NumberBox
                x:Name="DebounceBox"
                Header="Debounce interval (ms)"
                Value="500"
                Minimum="50"
                Maximum="5000"
                SpinButtonPlacementMode="Inline"
                SmallChange="50" />

            <!-- ── Logging ────────────────────────────────────────────────── -->
            <TextBlock Text="Logging" Style="{StaticResource SubtitleTextBlockStyle}" />

            <ComboBox
                x:Name="LogLevelBox"
                Header="Log level"
                HorizontalAlignment="Stretch">
                <x:String>error</x:String>
                <x:String>warn</x:String>
                <x:String>info</x:String>
                <x:String>debug</x:String>
                <x:String>trace</x:String>
            </ComboBox>

            <ToggleSwitch
                x:Name="RedactPiiToggle"
                Header="Redact PII in logs"
                OffContent="File paths and tags are logged as-is"
                OnContent="File paths and tags replaced with [REDACTED]"
                IsOn="True" />

            <!-- ── Config File ────────────────────────────────────────────── -->
            <TextBlock Text="Config File" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="ConfigPathBox"
                    Grid.Column="0"
                    IsReadOnly="True"
                    FontFamily="Cascadia Mono, Consolas, monospace"
                    FontSize="12" />

                <Button
                    Grid.Column="1"
                    Content="Open Folder"
                    Click="OpenFolderButton_Click" />

                <Button
                    Grid.Column="2"
                    Content="Copy Path"
                    Click="CopyPathButton_Click" />
            </Grid>

            <!-- Raw config preview -->
            <TextBlock Text="Raw Config (read-only)" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                MaxHeight="240">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox
                        x:Name="RawConfigBox"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Mono, Consolas, monospace"
                        FontSize="12"
                        BorderThickness="0"
                        Background="Transparent"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <!-- ── Save Settings ─────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock
                    x:Name="SaveStatusText"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="12" />
                <Button
                    x:Name="SaveButton"
                    Content="Save Settings"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SaveButton_Click" />
            </StackPanel>

            <!-- Core version -->
            <TextBlock
                x:Name="VersionText"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                FontSize="11" />

        </StackPanel>
    </ScrollViewer>
</Page>
