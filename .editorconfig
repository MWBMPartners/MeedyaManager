# (C) 2025-2026 MWBM Partners Ltd
# EditorConfig — cross-editor formatting consistency
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Rust source files
[*.rs]
indent_size = 4

# Swift source files
[*.swift]
indent_size = 4

# C# source files
[*.cs]
indent_size = 4

# XAML files
[*.xaml]
indent_size = 4

# TOML configuration
[*.toml]
indent_size = 4

# YAML workflows
[*.{yml,yaml}]
indent_size = 2

# JSON/JSON5 configuration
[*.{json,json5}]
indent_size = 2

# Markdown documentation
[*.md]
trim_trailing_whitespace = false

# Makefile (tabs required)
[Makefile]
indent_style = tab

# Justfile
[justfile]
indent_style = space
indent_size = 4
