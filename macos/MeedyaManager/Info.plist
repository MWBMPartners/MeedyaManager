<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle display name shown to users -->
    <key>CFBundleName</key>
    <string>MeedyaManager</string>

    <!-- Human-readable display name -->
    <key>CFBundleDisplayName</key>
    <string>MeedyaManager</string>

    <!-- Unique bundle identifier -->
    <key>CFBundleIdentifier</key>
    <string>ltd.MWBMpartners.MeedyaManager</string>

    <!-- Bundle version (build number — incremented each build) -->
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Short version string shown to users (must match Cargo.toml workspace version) -->
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <!-- Bundle package type: application -->
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Info.plist format version -->
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Executable name -->
    <key>CFBundleExecutable</key>
    <string>MeedyaManager</string>

    <!-- App icon inside the bundle resources -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- Minimum macOS deployment target -->
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>

    <!-- Application category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>

    <!-- Support high-resolution displays -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Copyright notice -->
    <key>NSHumanReadableCopyright</key>
    <string>(C) 2025-2026 MWBM Partners Ltd. Licensed under GPL-2.0-or-later.</string>

    <!-- Principal class for SwiftUI app lifecycle -->
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
